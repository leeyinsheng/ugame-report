# ECS + OSS 部署用环境变量示例。
# 复制为 .env 后填写，再 `set -a; . ./.env; set +a` 导入，或写进 systemd 的 Environment。
# 不设 OSS_BUCKET 时，服务器自动改读本地 raw-data/ 目录。

# OSS 接入点：ECS 与 OSS 同区域时务必用「内网」endpoint（免流量费、更快）
# ⚠️ 这里填 OSS 服务接入点，不是你绑的自定义域名（如 ug9898.com）！
#    自定义域名只用于公网下载单个对象；SDK 列举/下载靠「接入点 + bucket 名」。
OSS_ENDPOINT=oss-cn-hongkong-internal.aliyuncs.com
# bucket 的真实名字（不是域名）
OSS_BUCKET=your-bucket-name
OSS_PREFIX=raw-data/

# 区域 ID。填了即用 V4 签名（新区域/新桶推荐）。如 cn-hongkong、cn-shanghai
OSS_REGION=cn-hongkong

# —— 鉴权二选一 ——
# 方式1（推荐，最安全）：给 ECS 绑定 RAM 角色，仅填角色名，无需密钥落地
# OSS_RAM_ROLE=your-ecs-ram-role-name

# 方式2：AccessKey（请用仅含该 bucket 只读权限的 RAM 子账号）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
